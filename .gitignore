/output/
/tests/output/

# Large data files
*.fastq
*.fastq.gz
*.gz
*.fq
*.fq.gz

# IDE and Editor settings
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# python relative files
__pycache__
*.pyc

# test report
*test_report*

